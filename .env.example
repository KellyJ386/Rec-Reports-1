# RecReports environment variables (copy to .env.local and fill in).
# Never commit real values. facility_id is NEVER an env var — it is resolved
# server-side from the authenticated session (CLAUDE.md §3.1).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by privileged server code (never sent to the client bundle).
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="RecReports <noreply@send.recreports.com>"

# --- Billing (Stripe) — annual subscriptions only (placeholder in MVP) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
