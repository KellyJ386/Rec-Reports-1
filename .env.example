NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://example-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
SUPABASE_JWT_SECRET=replace-with-server-only-jwt-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
OBSERVABILITY_DSN=https://example.invalid/observability

# Notification worker (scripts/notification-worker.mjs). Defaults to the safe
# "log" transport; set these to deliver real notifications.
NOTIFICATION_TRANSPORT=log
# NOTIFICATION_WEBHOOK_URL=https://your-relay.example.com/hook   # when TRANSPORT=webhook
# SENDGRID_API_KEY=replace-with-sendgrid-api-key                 # when TRANSPORT=sendgrid
# NOTIFICATION_FROM_EMAIL=noreply@your-domain.example            # when TRANSPORT=sendgrid
